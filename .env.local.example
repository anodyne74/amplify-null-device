# Environment Variables for Next.js & Amplify Configuration

# AWS Amplify Region
NEXT_PUBLIC_API_REGION=us-east-1

# AWS Amplify App ID (get from AWS Console)
# NEXT_PUBLIC_AMPLIFY_APP_ID=<your-app-id>

# Environment (local|staging|production)
NEXT_PUBLIC_ENVIRONMENT=local

# Cognito Configuration
NEXT_PUBLIC_COGNITO_REGION=us-east-1
# NEXT_PUBLIC_COGNITO_USER_POOL_ID=<user-pool-id>
# NEXT_PUBLIC_COGNITO_CLIENT_ID=<client-id>

# API Endpoint (if using custom backend)
# NEXT_PUBLIC_API_ENDPOINT=https://api.example.com

# S3 Configuration for file storage
# NEXT_PUBLIC_S3_BUCKET=<bucket-name>
# NEXT_PUBLIC_S3_REGION=us-east-1

# Feature Flags
NEXT_PUBLIC_ENABLE_ANALYTICS=true
NEXT_PUBLIC_ENABLE_DEBUG_LOGS=false

# Session Configuration
NEXT_PUBLIC_SESSION_TIMEOUT_MINUTES=30
NEXT_PUBLIC_SESSION_WARNING_MINUTES=5
